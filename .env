# HashFlow Deployment Environment Variables
# Copy this file to .env and fill in the values

# Chain ID (133 = HashKey Chain)
CHAIN_ID=133

# Address that pays gas and deploys the contracts.
DEPLOYER_ADDRESS=0xD7c271d20c9E323336bFC843AEb8deC23B346352

# Private key of the deployer (used by forge script --private-key).
PRIVATE_KEY=6b195a8d80239d39c03c7c65cdef77309c19c8f631f50bd78bcce7f42c4c525e

# Platform owner address (receives yield fees)
PLATFORM_ADDRESS=0xD7c271d20c9E323336bFC843AEb8deC23B346352

# HSP Address (HashKey Settlement Protocol - USDC on HashKey Testnet)
HSP_ADDRESS=0x79AEc4EeA31D50792F61D1Ca0733C18c89524C9e

# Auto service fee vault (20% of tax for platform operations) - defaults to PLATFORM_ADDRESS if empty
AUTO_SERVICE_FEE_VAULT_ADDRESS=