# HashFlow Protocol — Environment Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.

# ── Deployment ────────────────────────────────────
# Address that pays gas and deploys the contracts.
DEPLOYER_ADDRESS=0xYourDeployerAddressHere

# Private key of the deployer (used by forge script --private-key).
PRIVATE_KEY=0xYourPrivateKeyHere

# Address that collects the tax on each milestone release (Legacy).
TAX_VAULT_ADDRESS=0xYourTaxVaultAddressHere

# Phase 2: Regional/Government tax vault (80% of tax).
REGIONAL_TAX_VAULT_ADDRESS=0xYourRegionalVaultAddressHere

# Phase 2: Platform service fee vault (20% of tax).
AUTO_SERVICE_FEE_VAULT_ADDRESS=0xYourServiceFeeVaultAddressHere

# Platform owner — receives 50 % of yield on each release.
# Also becomes the Ownable owner of HashFlowEscrow and MockVault.
PLATFORM_ADDRESS=0xYourPlatformAddressHere

# ── HashKey Chain Testnet ─────────────────────────
# RPC endpoint (already configured in foundry.toml)
HASHKEY_TESTNET_RPC=https://hashkeychain-testnet.alt.technology

# Chain ID for HashKey Chain Testnet
HASHKEY_TESTNET_CHAIN_ID=133

# ── Deployed Contract Addresses (filled after deploy) ──────────────────
# Update these after running: forge script script/Deploy.s.sol:Deploy --broadcast
SETTLEMENT_TOKEN=
VAULT_ADDRESS=
ESCROW_ADDRESS=
HSP_ADDRESS=
